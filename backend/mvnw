#!/bin/sh
# Maven wrapper script for Unix/Linux/macOS
# Downloaded from https://maven.apache.org/wrapper/

set -e

if [ -z "$JAVA_HOME" ]; then
  JAVA_HOME=$(java -XshowSettings:all -version 2>&1 | grep java.home | sed 's/.*= //')
fi

MAVEN_PROJECTBASEDIR="${MAVEN_BASEDIR:-$(dirname "$0")}"
MAVEN_WRAPPER_JAR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"
MAVEN_WRAPPER_PROPERTIES="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.properties"

# If wrapper jar doesn't exist, download it
if [ ! -f "$MAVEN_WRAPPER_JAR" ]; then
  WRAPPER_URL=$(grep wrapperUrl "$MAVEN_WRAPPER_PROPERTIES" | cut -d= -f2-)
  if command -v curl > /dev/null; then
    curl -o "$MAVEN_WRAPPER_JAR" "$WRAPPER_URL" -f
  elif command -v wget > /dev/null; then
    wget -O "$MAVEN_WRAPPER_JAR" "$WRAPPER_URL"
  fi
fi

exec "$JAVA_HOME/bin/java" -jar "$MAVEN_WRAPPER_JAR" "$@"
